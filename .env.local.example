# Local development environment example (DO NOT COMMIT REAL SECRETS)
# Copy this to .env.local and fill values for local testing.

# Server settings
NODE_ENV=development
PORT=5000

# App secrets (generate strong values)
SESSION_SECRET=qwertyuiop

# Database (optional for local dev / set if needed)
#DATABASE_URL=postgresql://user:pass@host:5432/dbname

# SMS gateway (point to your Pi)
SMS_MODE=push
SMS_GATEWAY_URL=http://192.168.5.160:8080/sms/send
SMS_GATEWAY_TOKEN=qwertyuiop

# Telegram (optional)
#TELEGRAM_BOT_TOKEN=

# Email (optional)
#EMAIL_HOST=smtp.example.com
#EMAIL_USER=you@example.com
#EMAIL_PASSWORD=
